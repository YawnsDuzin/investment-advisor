[Unit]
Description=Investment Advisor - 월간 섹터 리프레시 (매월 1일 07:45 KST)

[Timer]
# 매월 1일 07:45 KST — 06:30 메인 배치 + 07:30 meta-sync 이후 실행
# 일요일 08:00 ohlcv-cleanup과 겹치면 DB 부하 → 시간 차이 분리
OnCalendar=*-*-01 07:45:00 Asia/Seoul
Persistent=true
Unit=monthly-sector-refresh.service

[Install]
WantedBy=timers.target

# 이 파일을 .env로 복사한 뒤 값을 수정하세요
# cp .env.example .env     (Linux/Mac)
# copy .env.example .env   (Windows)

# =========================================
# PostgreSQL 접속 정보
# =========================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=investment_advisor
DB_USER=postgres
DB_PASSWORD=your_password_here

# =========================================
# 분석 파이프라인 설정 (AnalyzerConfig)
# =========================================
# MAX_ARTICLES_PER_FEED: RSS 피드당 최대 수집 기사 수. 값이 클수록 분석 품질 ↑, 토큰 소비 ↑.
MAX_ARTICLES_PER_FEED=5

# MAX_TURNS: Claude SDK 최대 턴 수 (Stage 1·2 공통). JSON-only 응답이므로 2면 충분합니다.
MAX_TURNS=1

# TOP_THEMES: Stage 2에서 심층분석 대상이 되는 상위 테마 수 (신뢰도 내림차순).
TOP_THEMES=2

# TOP_STOCKS_PER_THEME: 각 상위 테마에서 심층분석할 종목 수 (테마 내 우선순위 상위부터).
TOP_STOCKS_PER_THEME=2

# ENABLE_STOCK_ANALYSIS: Stage 2(종목 심층분석) 활성화 스위치.
# true / false (또는 1 / 0, yes / no, on / off) — false면 Stage 1 결과만 저장합니다.
ENABLE_STOCK_ANALYSIS=true

# ENABLE_STOCK_DATA: 실시간 주가 데이터 조회 활성화 스위치.
# true면 yfinance로 추천 종목의 현재가/PER/시총 등을 조회하여 Stage 2 프롬프트에 포함합니다.
# false면 Claude가 학습 데이터 기반으로 추정합니다. (yfinance 미설치 환경에서는 false로 설정)
ENABLE_STOCK_DATA=true

# =========================================
# 모델 설정 — 용도별 분리 (비용 최적화)
# =========================================
# MODEL_ANALYSIS: 분석(Stage 1·2)에 사용할 모델. 정확도 우선.
MODEL_ANALYSIS=claude-sonnet-4-6

# MODEL_TRANSLATE: 번역에 사용할 모델. 비용 최소화 (Haiku는 Sonnet 대비 ~1/5 비용).
MODEL_TRANSLATE=claude-haiku-4-5-20251001

# QUERY_TIMEOUT: Claude SDK 단일 쿼리 타임아웃 (초).
# 서버 부하 시 첫 토큰까지 수 분 걸릴 수 있으므로 여유 있게 설정하세요.
# 기본 900초(15분). 라즈베리파이 등 저사양 환경에서는 1200 권장.
QUERY_TIMEOUT=900

# =========================================
# 재분석 임계값
# =========================================
# MIN_NEW_NEWS: 이전 세션 대비 신규 뉴스가 이 수 미만이면 분석을 스킵합니다.
MIN_NEW_NEWS=5

# =========================================
# JWT 인증 (AuthConfig)
# =========================================
# AUTH_ENABLED: 인증 시스템 활성화 스위치. false면 기존 동작 100% 유지.
AUTH_ENABLED=false

# JWT_SECRET_KEY: JWT 서명 키. 프로덕션 배포 전 반드시 변경하세요.
# 생성 방법: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=INSECURE_DEFAULT_CHANGE_IN_PRODUCTION

# JWT_ALGORITHM: JWT 알고리즘
JWT_ALGORITHM=HS256

# ACCESS_TOKEN_EXPIRE_MINUTES: Access Token 만료 시간 (분)
ACCESS_TOKEN_EXPIRE_MINUTES=60

# REFRESH_TOKEN_EXPIRE_DAYS: Refresh Token 만료 시간 (일)
REFRESH_TOKEN_EXPIRE_DAYS=30

# ADMIN_EMAIL: 최초 Admin 계정 이메일
ADMIN_EMAIL=admin@example.com

# ADMIN_PASSWORD: 최초 Admin 계정 비밀번호 (반드시 변경)
ADMIN_PASSWORD=changeme123

# COOKIE_SECURE: HTTPS 전용 쿠키 (프로덕션에서는 true로 설정)
COOKIE_SECURE=false

# =========================================
# Top Picks 추천 엔진 (RecommendationConfig)
# =========================================
# 대시보드 "오늘의 Top Picks" 섹션에 표시될 종목을 선별하는 룰 기반 스코어링 가중치.
# 투자 제안(investment_proposals) 저장 후, Stage 3에서 점수를 계산하여 daily_top_picks에 저장합니다.

# 가중치 (점수 단위)
REC_W_CONVICTION_HIGH=30         # conviction=high 가점
REC_W_STAGE2_DONE=20             # Stage 2 심층분석 완료 가점
REC_W_DISCOVERY_EARLY=15         # early_signal / deep_value 가점
REC_W_ACTION_BUY=10              # action=buy 가점
REC_W_UPSIDE_HIGH=10             # 상승여력 20% 이상 가점
REC_W_UPSIDE_MID=5               # 상승여력 10% 이상 가점
REC_W_THEME_CONF_MULT=10         # 테마 신뢰도 × 이 값 (0~10점)
REC_W_STREAK_BONUS=5             # 테마 연속 등장(3일 이상) 보너스
REC_W_PRICED_PENALTY=15          # 급등 종목(already_run/1m +20%) 감점
REC_W_NOPRICE_PENALTY=10         # 실시간 가격 결측 감점

# 임계값
REC_UPSIDE_HIGH=20.0             # 상승여력 상 구간 기준(%)
REC_UPSIDE_MID=10.0              # 상승여력 중 구간 기준(%)
REC_MOMENTUM_OVERHEAT=20.0       # 급등 감점 발동 기준 (1개월 수익률 %)
REC_STREAK_THRESHOLD=3           # 테마 연속 등장 보너스 발동 일수

# 다양성 제약
REC_MAX_CANDIDATES=15            # AI 재정렬에 넘겨지는 후보 최대 수
REC_MAX_PER_THEME=2              # 같은 테마 최대 선정 수
REC_MAX_PER_SECTOR=3             # 같은 섹터 최대 선정 수
REC_TOP_N_DISPLAY=10             # 대시보드에 노출되는 최종 Top N

# AI 재정렬 (Stage 3b) — 선택적
# true로 설정 시 룰 기반 후보를 Claude SDK로 한 번 더 재정렬하고 근거/리스크를 생성합니다.
# 분석 배치 1회당 추가 SDK 호출 1회 → Max 5x 구독 사용량 증가에 유의하세요.
REC_ENABLE_AI_RERANK=false
REC_AI_RERANK_TOP_N=10           # AI가 선정할 최종 픽 수
REC_AI_RERANK_MAX_TURNS=2        # Stage 3 SDK 최대 턴 수


# 한국거래소 (https://data.krx.co.kr/) 접속 정보
KRX_ID=가입한아이디
KRX_PW=가입한비밀번호
